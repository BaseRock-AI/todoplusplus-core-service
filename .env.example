APP_NAME=todoplusplus-core-service
APP_HOST=0.0.0.0
APP_PORT=8081
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

APP_AUTH_USER=admin
APP_AUTH_PASSWORD=password123
DEFAULT_USER_USERNAME=user
DEFAULT_USER_PASSWORD=password123

JWT_SECRET_KEY=replace-with-strong-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

DATABASE_URL=postgresql+psycopg://todo:todo@localhost:5437/todo_app

KAFKA_BOOTSTRAP_SERVERS=localhost:9093
TOPIC_JIRA=todo-items-jira
TOPIC_EMAIL=todo-items-email
TOPIC_AUDIT=todo-items-audit

JIRA_ENABLED=false
JIRA_API_URL=https://your-domain.atlassian.net
JIRA_API_EMAIL=you@example.com
JIRA_API_TOKEN=your_jira_token
JIRA_PROJECT_KEY=DEMO
JIRA_ISSUE_TYPE=Task

EMAIL_ENABLED=false
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=you@gmail.com
EMAIL_SMTP_PASSWORD=your_gmail_app_password
EMAIL_FROM=you@gmail.com
EMAIL_RECIPIENT=you@gmail.com
